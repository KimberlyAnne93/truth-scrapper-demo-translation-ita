# game/script/demo/script_3_dwell.rpy:59
translate japanese script_3_61e8dfaf:

    # a "Yeah!{w} Every floor has one of those big locked doors.{w} But they're pretty easy to open!"
    a "そのとおり！{w} どの階層にも、こういうロックされた扉があるんだ。{w}開けるのはすごく簡単！"

# game/script/demo/script_3_dwell.rpy:60
